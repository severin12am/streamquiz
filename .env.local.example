# WhoSmarter — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's already in .gitignore).
# ============================================================

# ---- Supabase ----
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER-ONLY service role key (no NEXT_PUBLIC_ prefix — never exposed to
# the browser). Required so the server can create games after RLS forbids
# anon INSERTs on the games table. From: Supabase → Project Settings → API
# → "service_role" secret. KEEP THIS SECRET.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- AI question generation ----
# Primary provider: xAI (Grok). From: https://x.ai/api
# Server-only (no NEXT_PUBLIC_ prefix). If this fails or is missing, the
# server automatically falls back to OPENAI_API_KEY below.
XAI_API_KEY=xai-your-key-here
# Optional: override the model if xAI renames/retires the default (grok-4.3).
# XAI_MODEL=grok-4.3
# XAI_MODEL_EASY=grok-4.3

# Fallback provider (OpenRouter by default, or real OpenAI).
# From: platform.openai.com or openrouter.ai → API Keys. Server-only.
OPENAI_API_KEY=sk-your-key-here
# Optional: point the fallback at a different OpenAI-compatible endpoint.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ---- Stripe (web subscriptions) ----
# Secret (or restricted) API key from the merchant provider. Server-only.
# TEST mode: rk_test_... / LIVE mode: rk_live_...
STRIPE_SECRET_KEY=rk_test_your-key-here

# Webhook signing secret for POST /api/stripe/webhook. Provided by the
# merchant/Stripe when the webhook endpoint is registered (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Public site origin used for Checkout success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=https://whosmarter.com

# Optional: route Stripe API calls through a static-IP HTTPS proxy if the
# secret key is IP-restricted (Netlify egress IPs are dynamic).
# STRIPE_HTTP_PROXY=http://user:pass@proxy-host:port

# ---- Rate limiting (optional overrides) ----
# Max game creations / question generations per IP per 60s window.
# RL_CREATE_GAME_LIMIT=6
# RL_GENERATE_LIMIT=12
